# 按文件类型分组定义
# 文档类
*.md      text eol=lf linguist-documentation
*.txt     text eol=lf linguist-documentation
*.pdf     binary linguist-documentation

# 源代码 - SystemVerilog
*.sv      text eol=lf linguist-language=SystemVerilog
*.svh     text eol=lf linguist-language=SystemVerilog
*.v       text eol=lf linguist-language=Verilog
*.vh      text eol=lf linguist-language=Verilog

# 约束和配置文件
*.xdc     text eol=lf
*.qsf     text eol=lf
*.sdc     text eol=lf
*.tcl     text eol=lf

# 仿真脚本
*.sh      text eol=lf
*.bat     text eol=crlf
*.ps1     text eol=crlf

# 波形和日志
*.vcd     binary
*.fst     binary
*.log     text eol=lf
*.wlf     binary

# 通用二进制文件
*.png     binary
*.jpg     binary
*.gif     binary